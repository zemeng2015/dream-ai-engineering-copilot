diff --git a/src/main/java/com/democorp/demo/JobExecutionService.java b/src/main/java/com/democorp/demo/JobExecutionService.java
index 1111111..2222222 100644
--- a/src/main/java/com/democorp/demo/JobExecutionService.java
+++ b/src/main/java/com/democorp/demo/JobExecutionService.java
@@ -25,10 +25,18 @@ public class JobExecutionService {
     public String startJob(String jobId) {
         statusTracker.markSubmitted(jobId);
         boolean accepted = batchJobAdapter.submitBatchJob(jobId);
         if (accepted) {
             statusTracker.markRunning(jobId);
             return jobId;
         }
         statusTracker.markFailed(jobId);
         return jobId;
     }
+
+    public boolean isTerminalStatus(String jobId) {
+        JobStatus status = statusForJob(jobId);
+        return status == JobStatus.COMPLETED || status == JobStatus.FAILED;
+    }
+
+    public String statusMessageForJob(String jobId) {
+        return "job " + jobId + " is " + statusForJob(jobId).name().toLowerCase();
+    }
 }
