# SPDX-License-Identifier: Apache-2.0

# Default provider is mock. No key is needed for local demos or tests.
DREAM_LLM_PROVIDER=mock

# Optional OpenAI-compatible provider settings. Not used unless explicitly configured.
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
OPENAI_COMPATIBLE_API_KEY=
# OPENAI_API_KEY can also be used for the default OpenAI endpoint.
OPENAI_API_KEY=
OPENAI_COMPATIBLE_TIMEOUT_SECONDS=30
