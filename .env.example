# SPDX-License-Identifier: Apache-2.0

# Default provider is mock. No key is needed for local demos or tests.
DREAM_LLM_PROVIDER=mock

# Optional OpenAI-compatible provider settings. Not used unless explicitly configured.
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
OPENAI_COMPATIBLE_API_KEY=
# OPENAI_API_KEY can also be used for the default OpenAI endpoint.
OPENAI_API_KEY=
OPENAI_COMPATIBLE_TIMEOUT_SECONDS=30

# Qwen Cloud Hackathon mode. Set DREAM_CONFIG_FILE=examples/config/dream.qwen.yaml
# when running live Qwen-backed demos.
DASHSCOPE_API_KEY=
# Qwen Cloud Devpost resources list this OpenAI-compatible base URL.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
QWEN_TIMEOUT_SECONDS=30

# Optional deployment metadata surfaced by /health for Devpost proof.
ALIBABA_CLOUD_REGION=ap-southeast-1
ALIBABA_CLOUD_SERVICE=Function Compute custom container
ALIBABA_CLOUD_CONTAINER_IMAGE=
